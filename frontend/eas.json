{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "environment": "preview",
      "channel": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production-apk": {
      "environment": "production",
      "distribution": "internal",
      "channel": "production-apk",
      "android": {
        "buildType": "apk"
      },
      "prebuildCommand": "npx expo prebuild --platform android --clean"
    },
    "production": {
      "environment": "production",
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "prebuildCommand": "npx expo prebuild --platform android --clean"
    }
  }
}