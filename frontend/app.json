{
  "expo": {
    "name": "Quoridor",
    "slug": "quoridor",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quoridor",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.trilumosapp.quoridor",
      "runtimeVersion": "1.0.0"
    },
    "androidStatusBar": {
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#0D0D0D",
      "barStyle": "light-content"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "gradleProperties": {
              "org.gradle.internal.repository.max.retries": "8",
              "org.gradle.internal.repository.initial.backoff": "1000",
              "org.gradle.internal.http.connectionTimeout": "120000",
              "org.gradle.internal.http.socketTimeout": "120000"
            }
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4447692643301149~7670516774"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4d4af98a-2514-4485-9a1a-36b89656bfd0"
      }
    },
    "owner": "deepkakadiya25s-organization",
    "updates": {
      "url": "https://u.expo.dev/980de41e-3dc5-4979-9f40-e56b74ba3b78"
    }
  }
}
